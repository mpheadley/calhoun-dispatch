# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# interviews — raw audio and transcripts (large files)
interviews/*.mp3
interviews/*.wav
interviews/*.json

# ChatGPT export archives — transcripts are extracted into .md files; raw exports are too large for git
content/matt-headley-sources/chatgpt-export-annistonfirst-1/
content/matt-headley-sources/chatgpt-export-annistonfirst-2/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Large source videos — keep on disk, never commit
content/research/sources/*.mp4
content/research/sources/*.mov
content/research/sources/*.MP4
content/research/sources/*.MOV
